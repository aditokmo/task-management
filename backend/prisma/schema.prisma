generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  backlog
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum BoardInviteStatus {
  pending
  accepted
  declined
}

enum NotificationType {
  board_invite
  board_invite_accepted
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  googleId     String?  @unique
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks  Task[]
  boards Board[]
  boardMemberships BoardMember[]
  sentBoardInvites BoardMember[] @relation("BoardInviteSender")
  notifications Notification[]
  notificationActors Notification[] @relation("NotificationActor")
}

model Board {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks Task[]
  members BoardMember[]
  notifications Notification[]

  @@unique([ownerId, name])
  @@index([ownerId, updatedAt])
}

model BoardMember {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  invitedById String?
  status    BoardInviteStatus @default(accepted)
  createdAt DateTime @default(now())
  respondedAt DateTime?

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User? @relation("BoardInviteSender", fields: [invitedById], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@unique([boardId, userId])
  @@index([userId, status])
  @@index([invitedById])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  actorId   String?
  boardId   String?
  boardMemberId String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  board Board? @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardMember BoardMember? @relation(fields: [boardMemberId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([boardMemberId])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String       @default("")
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(backlog)
  dueDate     DateTime
  position    Int          @default(0)
  boardId     String?
  assigneeId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  board    Board? @relation(fields: [boardId], references: [id], onDelete: Cascade)
  assignee User?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([boardId, status, position])
}
